<!DOCTYPE html>
<html lang="en">
      <%- include("./partials/header.ejs")%>
  <body>
    <%- include("./partials/nav.ejs") %> 
    <div class="blogs content">
      <h2>All Blogs</h2>
        <% if (blogs.length > 0) { %>
        <% blogs.forEach((el) => { %>
                <h3 class="title"><%= el.title %></h3>
                <p class="snippet"><%= el.snippet %></p>
        <% }) %>
    <% } else { %>
        <h2>There are no blogs to show ......</h2>
    <% } %>

    </div><br>
    <%- include("./partials/footer") %>

  </body>
</html>
